# Copy this to .env and fill in your real values
# NEVER commit .env to git

# DataSpace credentials (kept server-side only)
DS_CLIENT_ID=your-client-id@industryapps.net
DS_CLIENT_SECRET=your-client-secret
DS_COMPANY_CODE=UATOCC
DS_PLANT_CODE=OCCUAT
DS_ENVIRONMENT=uat

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173
